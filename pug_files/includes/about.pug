            li jQuery
            li Bootstrap
            li Wordpress
            li React.js
      div.col-xl-3.offset-xl-1.col-lg-4.col-md-6
        div.about__card
          h2 Design
          ul.about__card__list
            li Adobe Illustrator
            li Adobe XD
            li Figma